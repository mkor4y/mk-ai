# MK AI - BIST Analiz Botu & Web API Çevre Değişkenleri Şablonu

# ==================== API ANAHTARLARI ====================
# Telegram Bot Token - BotFather'dan alınır
TELEGRAM_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key - DeepSeek ve diğer modeller için (isteğe bağlı)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key - Llama-3 modelleri için (hızlı ve önerilir)
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI Key - Haber analizleri için (https://newsapi.org/)
NEWSAPI_KEY=your_newsapi_key_here

# ==================== MODÜL AYARLARI ====================
# Hangi AI sağlayıcısı kullanılacak: 'groq' veya 'openrouter'
AI_PROVIDER=groq

# Log Seviyesi: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== TRADINGVIEW (İSTEĞE BAĞLI) ====================
# tvDatafeed kullanımı için (bazı veriler için giriş gerekebilir)
TV_USERNAME=your_username
TV_PASSWORD=your_password

# ==================== WEB API AYARLARI ====================
# Web API için CORS izinleri (virgülle ayrılmış URL listesi)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
