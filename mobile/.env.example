# MK AI Mobile - .env sablonu
# Bu dosyayi .env olarak kopyala ve degerleri kendi ortamina gore guncelle.
#
# Onemli: .env asset olarak APK'ya gomulur (pubspec.yaml -> flutter.assets).
# Yani build alinan sirada hangi URL varsa o gomulur.

# Production:
API_BASE_URL=https://m-koray.online/api

# Yerel gelistirme alternatifleri:
# - Android emulator:     API_BASE_URL=http://10.0.2.2:8000
# - Gercek cihaz (LAN):   API_BASE_URL=http://192.168.1.5:8000
# - iOS simulator:        API_BASE_URL=http://localhost:8000
